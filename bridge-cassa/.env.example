# IP locale della cassa VNE sulla LAN del Wash Hub
VNE_HOST=192.168.1.50

# Protocollo verso la cassa: https reale, http per test_mock.py
VNE_PROTOCOL=https

# Bearer token: genera con  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Esempio (NON usare in produzione, generane uno nuovo):
# BRIDGE_TOKEN=f_AIuhi21HS25r3XQKVu58yYCQw1v81678jx4jatuXPGVX2eJwVtDmuaoKJkWTBY
BRIDGE_TOKEN=GENERA_QUESTA_STRINGA_RANDOM_64_CHAR

# Operatore di default che firma le operazioni VNE
OP_NAME=dashdebug

# Porta locale (Cloudflare Tunnel inoltra cassa.washhub.it -> 127.0.0.1:PORT)
PORT=8765
