{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "comment": "Wash Hub Design System — Style Dictionary tokens. Compatible with Style Dictionary v3+.",

  "color": {
    "brand": {
      "gold-50":  { "value": "#FBF7EC", "$type": "color" },
      "gold-100": { "value": "#F4EAC9", "$type": "color" },
      "gold-200": { "value": "#E8D590", "$type": "color" },
      "gold-300": { "value": "#D9BC6A", "$type": "color" },
      "gold-400": { "value": "#C8A84E", "$type": "color", "$description": "Primary brand — --gold" },
      "gold-500": { "value": "#B8963E", "$type": "color", "$description": "Hover/pressed" },
      "gold-600": { "value": "#9A7B2F", "$type": "color" },
      "gold-700": { "value": "#7A6025", "$type": "color" },
      "gold-800": { "value": "#5A4519", "$type": "color" },
      "gold-900": { "value": "#3A2D0E", "$type": "color" }
    },
    "neutral": {
      "white":     { "value": "#FFFFFF", "$type": "color" },
      "bg":        { "value": "#F2F2F7", "$type": "color", "$description": "--bg: app background" },
      "bg2":       { "value": "#FFFFFF", "$type": "color", "$description": "--bg2: card/panel surface" },
      "bg3":       { "value": "#FFFFFF", "$type": "color", "$description": "--bg3: nested surface" },
      "bg4":       { "value": "#F9F9FB", "$type": "color", "$description": "--bg4: table header" },
      "border":    { "value": "rgba(0,0,0,0.06)", "$type": "color", "$description": "--brd" },
      "border2":   { "value": "rgba(0,0,0,0.10)", "$type": "color", "$description": "--brd2" },
      "text":      { "value": "#1C1C1E", "$type": "color", "$description": "--tx: primary text" },
      "text2":     { "value": "#636366", "$type": "color", "$description": "--tx2: secondary text" },
      "text3":     { "value": "#AEAEB2", "$type": "color", "$description": "--tx3: tertiary/label text" }
    },
    "semantic": {
      "success":       { "value": "#34C759", "$type": "color", "$description": "--grn" },
      "success-bg":    { "value": "rgba(52,199,89,0.10)", "$type": "color" },
      "danger":        { "value": "#FF3B30", "$type": "color", "$description": "--red" },
      "danger-bg":     { "value": "rgba(255,59,48,0.08)", "$type": "color" },
      "warning":       { "value": "#FF9500", "$type": "color", "$description": "--amb" },
      "warning-bg":    { "value": "rgba(255,149,0,0.10)", "$type": "color" },
      "info":          { "value": "#007AFF", "$type": "color", "$description": "--blu" },
      "info-bg":       { "value": "rgba(0,122,255,0.08)", "$type": "color" }
    },
    "alpha": {
      "gold-subtle": { "value": "rgba(200,168,78,0.08)", "$type": "color", "$description": "--gold-subtle" },
      "gold-ring":   { "value": "rgba(200,168,78,0.30)", "$type": "color", "$description": "--gold-ring: focus ring" },
      "gold-hover":  { "value": "rgba(200,168,78,0.06)", "$type": "color", "$description": "--gold-hover: table row hover" }
    },
    "surface": {
      "topbar":       { "value": "rgba(255,255,255,0.85)", "$type": "color" },
      "loader":       { "value": "rgba(255,255,255,0.92)", "$type": "color" },
      "modal-overlay":{ "value": "rgba(0,0,0,0.50)", "$type": "color" }
    },
    "location": {
      "lungomare-accent":    { "value": "#0077B6", "$type": "color", "$description": "Sede Lungomare — blu Mediterraneo" },
      "paesi-etnei-accent":  { "value": "#2D2D2D", "$type": "color", "$description": "Sede Paesi Etnei — grigio lavico" }
    }
  },

  "typography": {
    "fontFamily": {
      "ui":   { "value": "'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "value": "'JetBrains Mono', 'SF Mono', monospace", "$type": "fontFamily" }
    },
    "fontSize": {
      "kpi-display": { "value": "42px", "$type": "dimension" },
      "kpi":         { "value": "26px", "$type": "dimension" },
      "kpi-md":      { "value": "22px", "$type": "dimension" },
      "kpi-sm":      { "value": "20px", "$type": "dimension" },
      "kpi-xs":      { "value": "18px", "$type": "dimension" },
      "h1":          { "value": "22px", "$type": "dimension" },
      "h2":          { "value": "17px", "$type": "dimension" },
      "h3":          { "value": "15px", "$type": "dimension" },
      "body-lg":     { "value": "14px", "$type": "dimension" },
      "body":        { "value": "13px", "$type": "dimension" },
      "body-sm":     { "value": "12px", "$type": "dimension" },
      "caption":     { "value": "11px", "$type": "dimension" },
      "label":       { "value": "10px", "$type": "dimension" },
      "badge":       { "value": "10px", "$type": "dimension" }
    },
    "fontWeight": {
      "regular":   { "value": "400", "$type": "fontWeight" },
      "medium":    { "value": "500", "$type": "fontWeight" },
      "semibold":  { "value": "600", "$type": "fontWeight" },
      "bold":      { "value": "700", "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":   { "value": "1.2", "$type": "number" },
      "normal":  { "value": "1.5", "$type": "number" }
    },
    "letterSpacing": {
      "tight-lg":  { "value": "-0.8px", "$type": "dimension", "$description": "KPI values" },
      "tight-md":  { "value": "-0.5px", "$type": "dimension", "$description": "KPI mobile, headings" },
      "tight-sm":  { "value": "-0.3px", "$type": "dimension", "$description": "topbar h2" },
      "none":      { "value": "0px", "$type": "dimension" },
      "wide-xs":   { "value": "0.3px", "$type": "dimension", "$description": "badge" },
      "wide-sm":   { "value": "0.5px", "$type": "dimension", "$description": "loader text" },
      "wide-md":   { "value": "0.8px", "$type": "dimension", "$description": "form field label" },
      "wide-lg":   { "value": "1px", "$type": "dimension", "$description": "table header" },
      "wide-xl":   { "value": "1.5px", "$type": "dimension", "$description": "KPI label" },
      "wide-2xl":  { "value": "2px", "$type": "dimension", "$description": "sidebar section" },
      "wide-3xl":  { "value": "3px", "$type": "dimension", "$description": "login subtitle" }
    }
  },

  "spacing": {
    "1":  { "value": "4px",  "$type": "dimension" },
    "2":  { "value": "8px",  "$type": "dimension" },
    "3":  { "value": "12px", "$type": "dimension" },
    "4":  { "value": "16px", "$type": "dimension" },
    "5":  { "value": "20px", "$type": "dimension" },
    "6":  { "value": "24px", "$type": "dimension" },
    "7":  { "value": "28px", "$type": "dimension" },
    "8":  { "value": "32px", "$type": "dimension" },
    "10": { "value": "40px", "$type": "dimension" }
  },

  "borderRadius": {
    "sm":   { "value": "6px",  "$type": "dimension" },
    "md":   { "value": "10px", "$type": "dimension", "$description": "--r2: inputs, buttons, badges" },
    "lg":   { "value": "14px", "$type": "dimension", "$description": "--r: cards, panels, tables" },
    "xl":   { "value": "20px", "$type": "dimension", "$description": "--r3: pills, search box" },
    "full": { "value": "9999px", "$type": "dimension" },
    "circle": { "value": "50%", "$type": "dimension" }
  },

  "shadow": {
    "sm": {
      "value": "0 1px 2px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.03)",
      "$type": "shadow",
      "$description": "--shadow-sm: card default"
    },
    "md": {
      "value": "0 2px 8px rgba(0,0,0,0.04), 0 4px 16px rgba(0,0,0,0.04)",
      "$type": "shadow",
      "$description": "--shadow-md: card hover"
    },
    "lg": {
      "value": "0 4px 12px rgba(0,0,0,0.05), 0 8px 32px rgba(0,0,0,0.06)",
      "$type": "shadow",
      "$description": "--shadow-lg"
    },
    "xl": {
      "value": "0 8px 24px rgba(0,0,0,0.08), 0 16px 48px rgba(0,0,0,0.06)",
      "$type": "shadow",
      "$description": "--shadow-xl: modals"
    },
    "modal": {
      "value": "0 12px 40px rgba(0,0,0,0.50)",
      "$type": "shadow"
    },
    "button-gold": {
      "value": "0 2px 8px rgba(200,168,78,0.30)",
      "$type": "shadow"
    },
    "button-gold-hover": {
      "value": "0 4px 12px rgba(200,168,78,0.30)",
      "$type": "shadow"
    },
    "focus-gold": {
      "value": "0 0 0 3px rgba(200,168,78,0.30)",
      "$type": "shadow",
      "$description": "Input focus ring"
    }
  },

  "motion": {
    "duration": {
      "fast":       { "value": "150ms", "$type": "duration" },
      "normal":     { "value": "250ms", "$type": "duration" },
      "slow":       { "value": "350ms", "$type": "duration" },
      "extra-slow": { "value": "500ms", "$type": "duration" }
    },
    "easing": {
      "default":    { "value": "ease",                        "$type": "cubicBezier" },
      "linear":     { "value": "linear",                      "$type": "cubicBezier" },
      "ios-slide":  { "value": "cubic-bezier(.32,.72,0,1)",   "$type": "cubicBezier" }
    }
  },

  "layout": {
    "sidebar-width":       { "value": "260px", "$type": "dimension" },
    "sidebar-width-mobile":{ "value": "300px", "$type": "dimension" },
    "topbar-z":            { "value": "50",    "$type": "number" },
    "sidebar-z":           { "value": "40",    "$type": "number" },
    "modal-z":             { "value": "100",   "$type": "number" },
    "loader-z":            { "value": "999",   "$type": "number" },
    "blur-topbar":         { "value": "20px",  "$type": "dimension" },
    "blur-loader":         { "value": "20px",  "$type": "dimension" },
    "breakpoint-mobile":   { "value": "768px", "$type": "dimension" },
    "breakpoint-sm":       { "value": "430px", "$type": "dimension" },
    "breakpoint-xs":       { "value": "380px", "$type": "dimension" }
  }
}
