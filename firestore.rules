rules_version = '2';

// ═══════════════════════════════════════════════════════════════════
// WASHHUB DASHBOARD — Firestore Security Rules
// Project: dashboard-washhub
//
// Modello di autorizzazione:
//   • admin    → email in lista → accesso completo a tutte le sedi
//   • operator → utente autenticato → accesso solo alla propria sede
//                (per ora: lungomare; espandibile via /utenti/{uid}.sedi)
//   • pubblico → non autenticato → solo create su prenotazioni (form prenota.html)
//
// Multi-sede: ogni documento operativo deve avere il campo sedeId.
//   Operatori possono leggere e scrivere solo documenti della propria sede.
//   Admin ignorano il filtro sede.
// ═══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: autenticazione ───────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
          && request.auth.token.email != null
          && (
              request.auth.token.email.lower() == 'amministrazione@avrlogisticarl.com'
              || request.auth.token.email.lower() == 'michela@avrlogisticarl.com'
             );
    }

    function isOperator() {
      return isSignedIn() && !isAdmin();
    }

    // ── Helper: controllo sede ────────────────────────────────────
    // Admin accede a tutte le sedi.
    // Operator: solo lungomare per ora.
    // FASE 2: sostituire con:
    //   get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data.sedi.hasAny([sedeId])
    function hasSedeAccess(sedeId) {
      return isAdmin()
          || (isOperator() && sedeId == 'lungomare');
    }

    // Sede valida = uno dei valori noti. Blocca typo e injection.
    function sedeValida(sedeId) {
      return sedeId == 'lungomare' || sedeId == 'paesi-etnei';
    }

    // Write valido: sedeId presente, valido, e utente ha accesso a quella sede.
    function writeOk() {
      return request.resource.data.sedeId is string
          && sedeValida(request.resource.data.sedeId)
          && hasSedeAccess(request.resource.data.sedeId);
    }

    // ── Helper: Prima Nota — restrizione lettura operatore ────────
    function startOfDayMs() {
      return request.time.toMillis()
           - (request.time.hours()   * 3600000)
           - (request.time.minutes() * 60000)
           - (request.time.seconds() * 1000);
    }

    // ═══════════════════════════════════════════════════════════
    // PRENOTAZIONI — accesso pubblico per form prenota.html
    // ═══════════════════════════════════════════════════════════
    match /prenotazioni/{doc} {
      // Lettura: admin tutto, operator solo propria sede, pubblico per slot calendario
      allow read: if isAdmin()
               || (isOperator() && resource.data.sedeId == 'lungomare')
               || !isSignedIn();

      // Create: gestionale (autenticato + writeOk) o form pubblico (sedeId lungomare)
      allow create: if (isSignedIn() && writeOk())
                 || (!isSignedIn() && request.resource.data.sedeId == 'lungomare');

      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    // ═══════════════════════════════════════════════════════════
    // COLLEZIONI OPERATIVE — read/write filtrato per sede
    // ═══════════════════════════════════════════════════════════
    match /tappezzeria/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /abbonamenti/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /giornalieri/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /uscite/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /sospesi/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /presenzeDipendenti/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /cancellazioni/{doc} {
      allow create:         if writeOk();
      allow read, update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // CLIENTI — condivisi tra sedi, nessun filtro sedeId
    // ═══════════════════════════════════════════════════════════
    match /clienti/{doc} {
      allow read, write: if isSignedIn();
    }

    // ═══════════════════════════════════════════════════════════
    // PRIMA NOTA — admin tutto; operator crea sempre, legge solo oggi
    // ═══════════════════════════════════════════════════════════
    match /primaNota/{doc} {
      allow create: if isSignedIn() && writeOk();

      allow read: if isAdmin()
               || (isOperator()
                   && hasSedeAccess(resource.data.sedeId)
                   && resource.data.timestamp is int
                   && resource.data.timestamp >= startOfDayMs());

      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // CONFIG — parametri operativi (cassa automatica VNE)
    // ═══════════════════════════════════════════════════════════
    match /config/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // SERVIZI ACCESSORI — admin gestisce, operator legge
    // ═══════════════════════════════════════════════════════════
    match /serviziAccessori/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // CHIUSURE — giorni chiusura straordinari (form pubblico legge)
    // ═══════════════════════════════════════════════════════════
    match /chiusure/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // GIORNATE CHIUSE — config calendario prenotazioni
    // ═══════════════════════════════════════════════════════════
    match /giornateChiuse/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // UTENTI — profili sede per Fase 2 multi-sede
    // Ogni documento leggibile solo dall'utente stesso e dagli admin.
    // ═══════════════════════════════════════════════════════════
    match /utenti/{uid} {
      allow read:  if isAdmin() || request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ═══════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
