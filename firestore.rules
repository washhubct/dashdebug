rules_version = '2';

// ═══════════════════════════════════════════════════════════════════
// WASHHUB DASHBOARD — Firestore Security Rules
// Project: dashboard-washhub
//
// Modello di autorizzazione:
//   • admin    → email in lista → accesso completo a tutte le sedi
//   • operator → utente autenticato → accesso solo alla propria sede
//                (per ora: lungomare; espandibile via /utenti/{uid}.sedi)
//   • pubblico → non autenticato → solo create su prenotazioni (form prenota.html)
//
// Multi-sede: ogni documento operativo deve avere il campo sedeId.
//   Operatori possono leggere e scrivere solo documenti della propria sede.
//   Admin ignorano il filtro sede.
// ═══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: autenticazione ───────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
          && request.auth.token.email != null
          && (
              request.auth.token.email.lower() == 'amministrazione@avrlogisticarl.com'
              || request.auth.token.email.lower() == 'michela@avrlogisticarl.com'
             );
    }

    function isOperator() {
      return isSignedIn() && !isAdmin();
    }

    // ── Helper: controllo sede ────────────────────────────────────
    // Admin accede a tutte le sedi.
    // Operator: legge sedi[] da /utenti/{uid}. Fallback a 'lungomare' se doc assente.
    function hasSedeAccess(sedeId) {
      return isAdmin()
          || (isOperator()
              && !exists(/databases/$(database)/documents/utenti/$(request.auth.uid))
              && sedeId == 'lungomare')
          || (isOperator()
              && exists(/databases/$(database)/documents/utenti/$(request.auth.uid))
              && get(/databases/$(database)/documents/utenti/$(request.auth.uid)).data.sedi.hasAny([sedeId]));
    }

    // Sede valida = uno dei valori noti. Blocca typo e injection.
    function sedeValida(sedeId) {
      return sedeId == 'lungomare' || sedeId == 'paesi-etnei';
    }

    // Write valido: sedeId presente, valido, e utente ha accesso a quella sede.
    function writeOk() {
      return request.resource.data.sedeId is string
          && sedeValida(request.resource.data.sedeId)
          && hasSedeAccess(request.resource.data.sedeId);
    }

    // ── Helper: Prima Nota — restrizione lettura operatore ────────
    // request.time è UTC. L'attività è in Italia (UTC+1/+2): senza correzione,
    // i pagamenti fatti tra mezzanotte e le 02:00 ora italiana cadono nel giorno
    // UTC precedente e l'operatore non potrebbe leggerli (rompendo la query).
    // Sottraiamo 2h (copre CET e CEST) per ancorare l'inizio giornata all'ora locale.
    function startOfDayMs() {
      return request.time.toMillis()
           - (request.time.hours()   * 3600000)
           - (request.time.minutes() * 60000)
           - (request.time.seconds() * 1000)
           - 7200000;
    }

    // ═══════════════════════════════════════════════════════════
    // PRENOTAZIONI — accesso pubblico per form prenota.html
    // ═══════════════════════════════════════════════════════════
    match /prenotazioni/{doc} {
      // Lettura: admin tutto, operator solo propria sede, pubblico per slot calendario
      allow read: if isAdmin()
               || (isOperator() && resource.data.sedeId == 'lungomare')
               || !isSignedIn();

      // Create: gestionale (autenticato + writeOk) o form pubblico (sedeId lungomare)
      allow create: if (isSignedIn() && writeOk())
                 || (!isSignedIn() && request.resource.data.sedeId == 'lungomare');

      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    // ═══════════════════════════════════════════════════════════
    // COLLEZIONI OPERATIVE — read/write filtrato per sede
    // ═══════════════════════════════════════════════════════════
    match /tappezzeria/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /abbonamenti/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /giornalieri/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /uscite/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /sospesi/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /presenzeDipendenti/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /incassiManuali/{doc} {
      allow read:           if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow create:         if writeOk();
      allow update, delete: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
    }

    match /cancellazioni/{doc} {
      allow create:         if writeOk();
      allow read, update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // CLIENTI — condivisi tra sedi, nessun filtro sedeId
    // ═══════════════════════════════════════════════════════════
    match /clienti/{doc} {
      allow read, write: if isSignedIn();
    }

    // ═══════════════════════════════════════════════════════════
    // PRIMA NOTA — admin tutto; operator crea sempre, legge solo oggi
    // ═══════════════════════════════════════════════════════════
    match /primaNota/{doc} {
      allow create: if isSignedIn() && writeOk();

      allow read: if isAdmin()
               || (isOperator()
                   && hasSedeAccess(resource.data.sedeId)
                   && resource.data.timestamp is int
                   && resource.data.timestamp >= startOfDayMs());

      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // CONFIG — parametri operativi (cassa automatica VNE)
    // ═══════════════════════════════════════════════════════════
    match /config/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // SERVIZI ACCESSORI — admin gestisce, operator legge
    // ═══════════════════════════════════════════════════════════
    match /serviziAccessori/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // CHIUSURE — giorni chiusura straordinari (form pubblico legge)
    // ═══════════════════════════════════════════════════════════
    match /chiusure/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // GIORNATE CHIUSE — config calendario prenotazioni
    // ═══════════════════════════════════════════════════════════
    match /giornateChiuse/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // UTENTI — profili sede per Fase 2 multi-sede
    // Ogni documento leggibile solo dall'utente stesso e dagli admin.
    // ═══════════════════════════════════════════════════════════
    match /utenti/{uid} {
      allow read:  if isAdmin() || request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // REFERRAL — programma "Porta un amico"
    // Lettura pubblica. Il sito (anonimo) può fare SOLO due scritture:
    //  1) "claim": al primo lookup su /referral salva telefono/codice
    //     del titolare (una sola volta — telefono non sovrascrivibile)
    //  2) incremento contatori: esattamente +1 su totale e inAttesa
    //     alla prenotazione con codice amico valido
    // Tutto il resto (conferme, rollback, vouchersAttivi) è riservato
    // agli operatori autenticati del gestionale.
    // ═══════════════════════════════════════════════════════════
    match /referral/{code} {
      allow read:   if true;
      allow create: if isSignedIn()
        || (request.resource.data.keys().hasOnly(['telefono', 'codice', 'primoLookup'])
            && request.resource.data.codice == code);
      allow update: if isSignedIn()
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['telefono', 'codice', 'primoLookup'])
            && !('telefono' in resource.data)
            && request.resource.data.codice == code)
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totale', 'inAttesa', 'ultimoAggiornamento'])
            && request.resource.data.totale == resource.data.get('totale', 0) + 1
            && request.resource.data.inAttesa == resource.data.get('inAttesa', 0) + 1);
      allow delete: if isAdmin();
    }

    match /referral/{code}/eventi/{tel} {
      allow read:           if isAdmin();
      allow create:         if true;
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // VOUCHERS — buoni sconto referral
    // read pubblico per validazione codice in /prenota.
    // create/update solo admin (emissione e marcatura "utilizzato").
    // list solo admin (sicurezza: niente enumerazione voucher altrui).
    // ═══════════════════════════════════════════════════════════
    match /vouchers/{id} {
      allow get:    if true;
      allow list:   if isAdmin();
      allow create: if isAdmin();
      // Update consentito a operatori della stessa sede (per marcare "utilizzato"
      // al saldo della prenotazione di riscatto).
      allow update: if isSignedIn() && hasSedeAccess(resource.data.sedeId);
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════
    // SMS LOG — scritto solo da Cloud Function (Admin SDK)
    // ═══════════════════════════════════════════════════════════
    match /smsLog/{doc} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════
    // WHATSAPP CHATS — Meta Cloud API integration
    // Le chat sono asset condiviso tra operatori (no filtro sede).
    // Scritture lato client solo per markAsRead / archivia / tag.
    // I messaggi (sub-collection) sono scritti solo da Cloud Function
    // (webhook inbound, send outbound) tramite Admin SDK.
    // ═══════════════════════════════════════════════════════════
    match /whatsappChats/{phone} {
      allow read:           if isSignedIn();
      allow update:         if isSignedIn();
      allow create, delete: if false;

      match /messages/{msgId} {
        allow read:  if isSignedIn();
        allow write: if false;
      }
    }

    // ═══════════════════════════════════════════════════════════
    // DEFAULT DENY
    // ═══════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
